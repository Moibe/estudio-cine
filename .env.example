# fal.ai API key — get one at https://fal.ai/dashboard/keys
# Server-only secret; do NOT prefix with PUBLIC_ or it will be exposed to the client.
FAL_KEY=

# SQLite database file path.
# Local dev: relative path is fine. Production (DigitalOcean droplet): use a stable path
# outside the deploy folder, e.g. /var/lib/estudio-cine/data.db
DATABASE_URL=./local.db
