# fal.ai API key — get one at https://fal.ai/dashboard/keys
# Server-only secret; do NOT prefix with PUBLIC_ or it will be exposed to the client.
FAL_KEY=

# OpenAI API key — get one at https://platform.openai.com/api-keys
# Used by the script builder to extract scenes from uploaded screenplays.
OPENAI_API_KEY=

# SQLite database file path.
# Local dev: relative path is fine. Production (DigitalOcean droplet): use a stable path
# outside the deploy folder, e.g. /var/lib/estudio-cine/data.db
DATABASE_URL=./local.db

# Directory where uploaded files (scripts, etc.) are stored.
# Local dev: relative path is fine. Production: use a stable path outside the deploy folder,
# e.g. /var/lib/estudio-cine/uploads
UPLOADS_DIR=./uploads
